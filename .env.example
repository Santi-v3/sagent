# Runtime
SAGENT_ENV=development
SAGENT_HOST=127.0.0.1
SAGENT_PORT=8765

# Workspace access remains disabled until explicitly selected by the user.
SAGENT_WORKSPACE_ROOT=

# Network and model integrations are disabled by default.
# Opt-in local model example (use all four values together):
# SAGENT_NETWORK_ENABLED=loopback
# SAGENT_LLM_PROVIDER=lm-studio
# SAGENT_LLM_BASE_URL=http://127.0.0.1:1234/v1
# SAGENT_LLM_MODEL=your-local-model-identifier
SAGENT_NETWORK_ENABLED=false
SAGENT_LLM_PROVIDER=disabled
SAGENT_LLM_BASE_URL=
SAGENT_LLM_MODEL=

# Local persistence
SAGENT_DATA_DIR=.sagent
SAGENT_LOG_LEVEL=INFO
