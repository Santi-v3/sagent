# Runtime
SAGENT_ENV=development
SAGENT_HOST=127.0.0.1
SAGENT_PORT=8765

# Workspace access remains disabled until explicitly selected by the user.
SAGENT_WORKSPACE_ROOT=

# Network and model integrations are disabled in the foundation phase.
SAGENT_NETWORK_ENABLED=false
SAGENT_LLM_PROVIDER=disabled
SAGENT_LLM_BASE_URL=

# Local persistence
SAGENT_DATA_DIR=.sagent
SAGENT_LOG_LEVEL=INFO
